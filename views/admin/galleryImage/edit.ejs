<div class="page-wrapper">
  <div class="row page-titles">
    <div class="col-md-5 align-self-center"><h3 class="text-primary">Dashboard</h3></div>
    <div class="col-md-7 align-self-center">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
        <li class="breadcrumb-item"><a href="/galleryImageSection">Gallery Images</a></li>
        <li class="breadcrumb-item active">Edit Image</li>
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h4 class="card-title">Edit Gallery Image</h4>
            <%- include('../../../inc/messages') %>
            <form action="/galleryImageSection/<%= galleryImg._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label>Gallery</label>
                <select name="gallery_name" class="form-control" required>
                  <option value="0">-- Select Gallery --</option>
                  <% galleries.forEach(function(g) { %>
                    <option value="<%= g._id %>" <%= galleryImg.gallery_id && g._id.toString() === galleryImg.gallery_id._id.toString() ? 'selected' : '' %>><%= g.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label>Current Image</label><br>
                <img style="width:120px;height:90px;" src="<%= galleryImg.image %>" alt="">
              </div>
              <div class="form-group">
                <label>Replace Image</label>
                <input class="form-control" name="gallery_image" type="file" accept="image/jpeg,image/png,image/jpg">
              </div>
              <div class="form-group">
                <label>Description</label>
                <input type="text" name="description" class="form-control" value="<%= galleryImg.description || '' %>">
              </div>
              <hr>
              <a href="/galleryImageSection" class="btn btn-danger">Back</a>
              <button type="submit" class="btn btn-success">Update</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
