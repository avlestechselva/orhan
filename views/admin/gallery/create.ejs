<div class="page-wrapper">
  <div class="row page-titles">
    <div class="col-md-5 align-self-center"><h3 class="text-primary">Dashboard</h3></div>
    <div class="col-md-7 align-self-center">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
        <li class="breadcrumb-item"><a href="/gallerySection">Gallery</a></li>
        <li class="breadcrumb-item active">Create Gallery</li>
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h4 class="card-title">Create Gallery</h4>
            <%- include('../../../inc/messages') %>
            <form action="/gallerySection" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label>Gallery Name</label>
                <input type="text" name="name" class="form-control" required placeholder="Gallery Name">
              </div>
              <div class="form-group">
                <label>Cover Image</label>
                <input class="form-control" name="gallery_cover_image" type="file" accept="image/jpeg,image/png,image/jpg">
              </div>
              <hr>
              <a href="/gallerySection" class="btn btn-danger">Back</a>
              <button type="submit" class="btn btn-success">Create</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
